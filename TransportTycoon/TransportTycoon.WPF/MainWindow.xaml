<Window x:Class="TransportTycoon.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TransportTycoon.WPF"
        xmlns:views="clr-namespace:TransportTycoon.WPF.View"
        xmlns:viewmodels="clr-namespace:TransportTycoon.WPF.ViewModel"
        mc:Ignorable="d"
        Title="TransportTycoon"
        Height="450"
        MinHeight="{Binding CurrentView.MinimumHeight, FallbackValue=450}"
        Width="800"
        MinWidth="{Binding CurrentView.MinimumWidth, FallbackValue=800}"
        
        Closing="Window_Closing"
        >
    
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:StartMenuViewModel}">
            <views:StartMenuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:GameViewModel}">
            <views:GameView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:CreateGameViewModel}">
            <views:CreateGameView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentView}" />
    </Grid>
</Window>
