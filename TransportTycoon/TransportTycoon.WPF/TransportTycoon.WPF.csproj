  <ItemGroup>
    <Resource Include="Assets\Images\Buttons\minus2.png">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Resource>
    <Resource Include="Assets\Images\Buttons\plus.png">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
