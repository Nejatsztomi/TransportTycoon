    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\Images\Buttons\minus.png" />
    <None Remove="Assets\Images\Buttons\plus.png" />
    <None Remove="Assets\Images\Road\crossT.png" />
    <None Remove="Assets\Images\Road\crossX.png" />
    <None Remove="Assets\Images\Road\road.png" />
    <None Remove="Assets\Images\Road\turn.png" />
    <None Remove="Assets\Images\Terrain\field.png" />
    <None Remove="Assets\Images\Terrain\highmountain.png" />
    <None Remove="Assets\Images\Terrain\highmountain2.png" />
    <None Remove="Assets\Images\Terrain\highmountain3.png" />
    <None Remove="Assets\Images\Terrain\hill.png" />
    <None Remove="Assets\Images\Terrain\mountain.png" />
    <None Remove="Assets\Images\Terrain\mountain2.png" />
    <None Remove="Assets\Images\Terrain\mountain3.png" />
