<UserControl x:Class="TransportTycoon.WPF.View.UserControls.MinimapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >

    <Border BorderBrush="White"
            BorderThickness="2"
            Background="Black"
            >
        <Canvas x:Name="MinimapCanvas"
                Width="200"
                Height="200"
                ClipToBounds="True"
                PreviewMouseLeftButtonDown="MinimapCanvas_PreviewMouseLeftButtonDown"
                PreviewMouseMove="MinimapCanvas_PreviewMouseMove"
                PreviewMouseLeftButtonUp="MinimapCanvas_PreviewMouseLeftButtonUp"
                >
            <Image Source="{Binding MinimapImage}"
                   Width="200"
                   Height="200"
                   Stretch="Fill"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   />
            <Rectangle x:Name="MinimapViewportBox" 
                       Stroke="Yellow"
                       StrokeThickness="2" 
                       Fill="#40FFFF00" 
                       Width="50"
                       Height="50"
                       />
        </Canvas>
    </Border>
</UserControl>
