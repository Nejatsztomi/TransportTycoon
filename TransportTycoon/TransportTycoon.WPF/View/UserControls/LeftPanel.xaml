<UserControl x:Class="TransportTycoon.WPF.View.UserControls.LeftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="#ECECEC" CornerRadius="5">
            <TabControl Background="Transparent" BorderThickness="0">

                <!-- TabItem-ek stílusa (kiegészítve a fejléc szövegének megjelenítésével) -->
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Width" Value="60"/>
                        <Setter Property="Height" Value="60"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="#888"
                                            BorderThickness="1"
                                            >
                                        <ContentPresenter x:Name="contentPresenter"
                                                          ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="Black"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Egyedi Template a vonal hozzáadásához -->
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" MinHeight="90"/>
                                <!-- fejléc sora -->
                                <RowDefinition Height="2"/>
                                <!-- vonal sora -->
                                <RowDefinition Height="*"/>
                                <!-- tartalom sora -->
                            </Grid.RowDefinitions>

                            <!-- Fejléc panel (alapértelmezett TabPanel, görgethető) -->
                            <TabPanel Grid.Row="0"
                                      Name="HeaderPanel"
                                      Panel.ZIndex="1"
                                      KeyboardNavigation.TabIndex="1"
                                      IsItemsHost="True"
                                      HorizontalAlignment="Center"
                                      Margin="10"
                                      />

                            <!-- Elválasztó vonal -->
                            <Border Grid.Row="1"
                                    Background="Gray"
                                    Margin="10,0"
                                    />

                            <!-- Tartalom -->
                            <Border Grid.Row="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    >
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- TabItem-ek-->
                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Terrain/hill.png" Stretch="UniformToFill"/>
                    </TabItem.Background>
                    <WrapPanel Margin="15" HorizontalAlignment="Center">
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="1"
                                >
                            <Image Source="/Assets/Images/Buttons/minus.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="2"
                                >
                            <Image Source="/Assets/Images/Buttons/plus.png" Stretch="Uniform"/>
                        </Button>
                    </WrapPanel>
                </TabItem>

                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Road/road.png" Stretch="UniformToFill"/>
                    </TabItem.Background>

                    <WrapPanel Margin="15" HorizontalAlignment="Center">
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="11"
                                >
                            <Image Source="/Assets/Images/Road/road.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="12"
                                >
                            <Image Source="/Assets/Images/Bridge/yellowBridge.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="13"
                                >
                            <Image Source="/Assets/Images/Stop/stop.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="14"
                                >
                            <Image Source="/Assets/Images/Buttons/x.png" Stretch="Uniform"/>
                        </Button>
                    </WrapPanel>
                </TabItem>

                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Vehicle/largeBus.png" Stretch="UniformToFill"/>
                    </TabItem.Background>
                    <WrapPanel Margin="15" HorizontalAlignment="Center">
                        <Button Width="50" Height="50" Margin="8"/>
                        <Button Width="50" Height="50" Margin="6"/>
                    </WrapPanel>
                </TabItem>

                <TabItem>
                    <WrapPanel Margin="15" HorizontalAlignment="Center">
                        <Button Width="50" Height="50" Margin="8"/>
                        <Button Width="50" Height="50" Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="100"
                                Background="Gold"
                                />
                    </WrapPanel>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
