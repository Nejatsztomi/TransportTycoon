<UserControl x:Class="TransportTycoon.WPF.View.UserControls.LeftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="OrangeRed" BorderBrush="Black" BorderThickness="2">

            <TabControl Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">

                <!-- TabItem design -->
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Width" Value="60"/>
                        <Setter Property="Height" Value="60"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Black"
                                            BorderThickness="2"
                                            >
                                        <ContentPresenter x:Name="contentPresenter"
                                                          ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="Yellow"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- TabControl design -->
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" MinHeight="90"/>
                                <!-- fejléc sora -->
                                <RowDefinition Height="2"/>
                                <!-- vonal sora -->
                                <RowDefinition Height="*"/>
                                <!-- tartalom sora -->
                            </Grid.RowDefinitions>

                            <!-- Fejléc panel (alapértelmezett TabPanel, görgethető) -->
                            <TabPanel Grid.Row="0"
                                      Name="HeaderPanel"
                                      Panel.ZIndex="1"
                                      KeyboardNavigation.TabIndex="1"
                                      IsItemsHost="True"
                                      HorizontalAlignment="Center"
                                      Margin="10"/>

                            <!-- Elválasztó vonal -->
                            <Border Grid.Row="1" Background="White" Margin="10,0"/>

                            <!-- Tartalom -->
                            <Border Grid.Row="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">

                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- TabItem-ek-->
                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Icons/terrain.png" Stretch="UniformToFill"/>
                    </TabItem.Background>
                    <WrapPanel Margin="14" HorizontalAlignment="Center">
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="11"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/minus.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="12"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/plus.png" Stretch="Uniform"/>
                        </Button>
                    </WrapPanel>
                </TabItem>

                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Icons/hammer.png" Stretch="UniformToFill"/>
                    </TabItem.Background>
                    <WrapPanel Margin="14" HorizontalAlignment="Center">
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="21"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/road.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="22"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/bridge.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="23"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/stop.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="24"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/x.png" Stretch="UniformToFill"/>
                        </Button>
                    </WrapPanel>
                </TabItem>

                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Icons/vehicle.png" Stretch="UniformToFill"/>
                    </TabItem.Background>
                    <WrapPanel Margin="14" HorizontalAlignment="Center">
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="31"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Vehicle/smallBus.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="32"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Vehicle/largeBus.png" Stretch="Uniform"/>
                        </Button>
                    </WrapPanel>
                </TabItem>

                <TabItem>
                    <TabItem.Background>
                        <ImageBrush ImageSource="/Assets/Images/Icons/route.png" Stretch="UniformToFill"/>
                    </TabItem.Background>
                    <WrapPanel Margin="14" HorizontalAlignment="Center">
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="41"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Buttons/route.png" Stretch="UniformToFill"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="42"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Buttons/pull.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="43"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Buttons/push.png" Stretch="Uniform"/>
                        </Button>
                        <Button Width="50" Height="50"
                                Margin="8"
                                Command="{Binding SetSelectedButtonCommand}"
                                CommandParameter="44"
                                Background="White"
                                BorderBrush="Black" BorderThickness="2">
                            <Image Source="/Assets/Images/Icons/x.png" Stretch="Uniform"/>
                        </Button>
                    </WrapPanel>
                </TabItem>
            </TabControl>

        </Border>
    </Grid>
</UserControl>
