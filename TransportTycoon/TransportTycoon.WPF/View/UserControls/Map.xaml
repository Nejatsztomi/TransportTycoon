<UserControl x:Class="TransportTycoon.WPF.View.UserControls.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel"
             xmlns:usercontrols="clr-namespace:TransportTycoon.WPF.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >
    <Grid>
        <usercontrols:FastMapRenderer x:Name="InternalGameMapRenderer"
                                      Map="{Binding Tiles}"
                                      Vehicles="{Binding Vehicles}"
                                      ClipToBounds="True"
                                      PreviewMouseRightButtonDown="GameMapRenderer_PreviewMouseRightButtonDown"
                                      PreviewMouseMove="GameMapRenderer_PreviewMouseMove"
                                      PreviewMouseRightButtonUp="GameMapRenderer_PreviewMouseRightButtonUp"
                                      PreviewMouseWheel="GameMapRenderer_PreviewMouseWheel"
                                      PreviewMouseLeftButtonDown="GameMapRenderer_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="GameMapRenderer_PreviewMouseLeftButtonUp"
                                      />
    </Grid>
</UserControl>
