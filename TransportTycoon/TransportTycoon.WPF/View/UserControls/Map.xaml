<UserControl x:Class="TransportTycoon.WPF.View.UserControls.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >
    <Grid>
        <Border
            Background="#2C2C2C"
            CornerRadius="5"
            ClipToBounds="True"
            >
            <Grid>
                <ScrollViewer
                     x:Name="MapScrollViewer"
                     HorizontalScrollBarVisibility="Hidden"
                     VerticalScrollBarVisibility="Hidden"
     
                     PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel"
                     PreviewMouseRightButtonDown="MapScrollViewer_PreviewMouseRightButtonDown"
                     PreviewMouseMove="MapScrollViewer_PreviewMouseMove"
                     PreviewMouseRightButtonUp="MapScrollViewer_PreviewMouseRightButtonUp"
                     >

                    <ItemsControl ItemsSource="{Binding Tiles}">
                        <ItemsControl.LayoutTransform>
                            <ScaleTransform
                                 ScaleX="{Binding ZoomLevel}"
                                 ScaleY="{Binding ZoomLevel}"
                             />
                        </ItemsControl.LayoutTransform>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid
                                     Columns="{Binding DataContext.MapColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                     Rows="{Binding DataContext.MapRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                 />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                 Width="50"
                                 Height="50"
                                 Background="Transparent"
                                 >
                                    <Grid.InputBindings>
                                        <MouseBinding 
                                           MouseAction="LeftClick" 
                                           Command="{Binding DataContext.TileLeftClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                           CommandParameter="{Binding}"
                                       />
                                    </Grid.InputBindings>

                                    <!-- Alap mező -->
                                    <Border
                                         BorderBrush="#404040"
                                         BorderThickness="1"
                                         >
                                        <Border.Background>
                                            <ImageBrush
                                                 ImageSource="{Binding ImagePath}" 
                                                 Stretch="UniformToFill" 
                                                 RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                />
                                        </Border.Background>
                                    </Border>

                                    <!-- Fák -->
                                    <Image Source="{Binding TreeImagePath, TargetNullValue={x:Null}, FallbackValue={x:Null}}"
                                           Stretch="UniformToFill" 
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           IsHitTestVisible="False"
                                           Margin="2"
                                           />

                                    <!-- Utak és hidak -->
                                    <Image Source="{Binding InfrastructureImagePath, TargetNullValue={x:Null}, FallbackValue={x:Null}}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           IsHitTestVisible="False"
                                           Margin="2"
                                           RenderTransformOrigin="0.5,0.5"
                                           >
                                            <Image.RenderTransform>
                                                <RotateTransform Angle="{Binding InfrastructureRotation}"/>
                                            </Image.RenderTransform>
                                    </Image>

                                    <!-- Épületek -->
                                    <Image Source="{Binding StructureImage, TargetNullValue={x:Null}, FallbackValue={x:Null}}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           IsHitTestVisible="False"
                                           Margin="2"
                                           />

                                    <Border x:Name="HoverOverlay" 
                                         Visibility="Hidden" 
                                         BorderBrush="Yellow" 
                                         BorderThickness="2" 
                                         Background="#33FFFFFF" 
                                         IsHitTestVisible="False"
                                         Panel.ZIndex="5"
                                         />

                                    <Border BorderBrush="Red" 
                                            BorderThickness="3" 
                                            Background="#33FFFFFF"
                                            >
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="HoverOverlay" Property="Visibility" Value="Visible" />

                                        <Setter Property="Panel.ZIndex" Value="1" />
                                    </Trigger>

                                    <!--<Trigger  ="{Binding IsSelected}" Value="True">
                                             
                                    </Trigger>-->
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>


                <Border HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Width="150" 
                    Height="150" 
                    Margin="20" 
                    BorderBrush="#404040" 
                    BorderThickness="2" 
                    Background="Black"
                    Opacity="0.9">
                    <Viewbox Stretch="Uniform">
                        <ItemsControl ItemsSource="{Binding Tiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid 
                                    Columns="{Binding DataContext.MapColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    Rows="{Binding DataContext.MapRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Rectangle Width="10" Height="10" Fill="{Binding MinimapColor}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
