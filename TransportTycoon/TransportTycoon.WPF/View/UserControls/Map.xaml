<UserControl x:Class="TransportTycoon.WPF.View.UserControls.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
             xmlns:usercontrols="clr-namespace:TransportTycoon.WPF.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >

    <Grid>
        <usercontrols:FastMapRenderer x:Name="GameMapRenderer"
                                      Map="{Binding Tiles2}"
                                      ClipToBounds="True"
                                      PreviewMouseRightButtonDown="GameMapRenderer_PreviewMouseRightButtonDown"
                                      PreviewMouseMove="GameMapRenderer_PreviewMouseMove"
                                      PreviewMouseRightButtonUp="GameMapRenderer_PreviewMouseRightButtonUp"
                                      PreviewMouseWheel="GameMapRenderer_PreviewMouseWheel"
                                      />
    </Grid>

</UserControl>
