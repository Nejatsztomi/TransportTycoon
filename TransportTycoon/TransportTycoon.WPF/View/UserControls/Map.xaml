<UserControl x:Class="TransportTycoon.WPF.View.UserControls.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel"
             xmlns:usercontrols="clr-namespace:TransportTycoon.WPF.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             >
    <Grid>
        <usercontrols:FastMapRenderer x:Name="GameMapRenderer"
                                      Map="{Binding Tiles2}"
                                      ClipToBounds="True"
                                      PreviewMouseRightButtonDown="GameMapRenderer_PreviewMouseRightButtonDown"
                                      PreviewMouseMove="GameMapRenderer_PreviewMouseMove"
                                      PreviewMouseRightButtonUp="GameMapRenderer_PreviewMouseRightButtonUp"
                                      PreviewMouseWheel="GameMapRenderer_PreviewMouseWheel"
                                      PreviewMouseLeftButtonDown="GameMapRenderer_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="GameMapRenderer_PreviewMouseLeftButtonUp"
                                      />

        <!-- Minimap -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="20"
                BorderBrush="White"
                BorderThickness="2" 
                Background="Black"
                >
            <Canvas x:Name="MinimapCanvas"
                    Width="200"
                    Height="200"
                    ClipToBounds="True"
                    >
                <Image Source="{Binding MinimapImage}"
                       Width="200"
                       Height="200"
                       Stretch="Fill"
                       />
                <Rectangle x:Name="MinimapViewportBox" 
                           Stroke="Yellow"
                           StrokeThickness="2" 
                           Fill="#40FFFF00" 
                           Width="50"
                           Height="50"
                           />
            </Canvas>
        </Border>
    </Grid>
</UserControl>
