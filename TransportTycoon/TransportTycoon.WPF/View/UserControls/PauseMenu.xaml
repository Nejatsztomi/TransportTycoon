<UserControl x:Class="TransportTycoon.WPF.View.UserControls.PauseMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View.UserControls" xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             FontFamily="/Assets/Fonts/#Press Start 2P">
    <Grid Background="#B2000000">

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="GAME PAUSED" 
                       FontSize="48" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"/>

            <Button Content="Resume" Width="300" Height="50" Margin="0,10" Command="{Binding ResumeGameCommand}"  FontSize="18"/>
            <Button Content="Save Game" Width="300" Height="50" Margin="0,10" Command="{Binding SaveGameCommand}" FontSize="18"/>
            <Button Content="Settings" Width="300" Height="50" Margin="0,10" FontSize="18"/>
            <Button Content="Back to Menu" Width="300" Height="50" Margin="0,10" Command="{Binding BackToMainMenuCommand}" FontSize="18"/>
            <Button Content="Quit to Desktop" Width="300" Height="50" Margin="0,10" Command="{Binding ExitGameCommand}" FontSize="18"/>
        </StackPanel>
    </Grid>
</UserControl>
