<UserControl x:Class="TransportTycoon.WPF.View.GameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TransportTycoon.WPF"
        xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
        xmlns:usercontrols="clr-namespace:TransportTycoon.WPF.View.UserControls"
        mc:Ignorable="d"
        Focusable="True"
        PreviewKeyDown="UserControl_PreviewKeyDown"
        MouseDown="UserControl_MouseDown"
        >

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <usercontrols:PauseMenu x:Name="PauseMenuOverlay"
             Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"
             Panel.ZIndex="100"
             />
        <DockPanel>
            <StatusBar DockPanel.Dock="Bottom" Height="50" Margin="10,0,10,10" 
                       Background="OrangeRed" BorderBrush="Black" BorderThickness="2"
                       Foreground="White" FontSize="15" FontFamily="/Assets/Fonts/#Press Start 2P">

                <StatusBar.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="Black"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Height" Value="35"/>
                    </Style>
                </StatusBar.Resources>

                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>

                <StatusBarItem Grid.Column="0" Margin="80,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="1x" Command="{Binding NormalSpeedCommand}" Margin="3,0" Width="35"/>
                        <Button Content="2x" Command="{Binding FastSpeedCommand}" Margin="3,0" Width="35"/>
                        <Button Content="4x" Command="{Binding SuperFastSpeedCommand}" Margin="3,0" Width="35"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem Grid.Column="1" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="EDIT" Command="{Binding EditorModeCommand}" Margin="2,0" Padding="10,2"/>
                        <Button Content="||" Command="{Binding EditorModeCommand}" Margin="2,0" Padding="10,2"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem Grid.Column="2" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Icons/coin.png" Width="35"/>
                        <TextBlock Margin="5,0,10,0" Text="{Binding Balance}" />
                        <Image Source="/Assets/Images/Icons/hourglass.png" Width="35"/>
                        <TextBlock Margin="0,0,10,0" Text="{Binding GameTime}" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="300"/>
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="8*" />
                </Grid.ColumnDefinitions>

                <!-- Left panel -->
                <usercontrols:LeftPanel Grid.Column="0"/>

                <!-- Right panel -->
                <usercontrols:Map x:Name="MainMapRenderer"
                              ViewModel="{Binding}"
                              Grid.Column="2"
                              />
                <usercontrols:MinimapControl
                Grid.Column="2"
                Margin="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                TargetRenderer="{Binding GameMapRenderer, ElementName=MainMapRenderer}"
                />
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
