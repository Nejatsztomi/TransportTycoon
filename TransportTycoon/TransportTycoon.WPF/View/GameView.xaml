<UserControl x:Class="TransportTycoon.WPF.View.GameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TransportTycoon.WPF"
        xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:GameViewModel}"
        xmlns:usercontrols="clr-namespace:TransportTycoon.WPF.View.UserControls"
        mc:Ignorable="d"
        Focusable="True"
        PreviewKeyDown="UserControl_PreviewKeyDown"
        MouseDown="UserControl_MouseDown"
        xmlns:conv="clr-namespace:TransportTycoon.WPF.ViewModel.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:SelectedButtonConverter x:Key="SelectedButtonConverter"/>
    </UserControl.Resources>

    <Grid Background="#E2D2AF">
        <usercontrols:PauseMenu x:Name="PauseMenuOverlay"
             Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"
             Panel.ZIndex="100"
             />
        <DockPanel>
            <StatusBar DockPanel.Dock="Bottom" Height="50" Margin="10,0,10,10" 
                       Background="OrangeRed" BorderBrush="Black" BorderThickness="2"
                       Foreground="White" FontSize="15" FontFamily="/Assets/Fonts/#Press Start 2P">

                <StatusBar.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="20"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="Black"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Width" Value="40"/>
                    </Style>
                    
                    <Style TargetType="RadioButton">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="20"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Width" Value="40"/>
                        
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            Background="White"
                                            BorderBrush="Black"
                                            BorderThickness="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="Yellow"/>
                                        </Trigger>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="LightGray"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StatusBar.Resources>

                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>

                <StatusBarItem Grid.Column="0" Margin="60,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Icons/speed.png" Stretch="Fill"/>
                        <RadioButton GroupName="Speed" Content="1" Command="{Binding NormalSpeedCommand}" Margin="3,0"
                                     IsChecked="{Binding SelectedSpeed, Converter={StaticResource SelectedButtonConverter}, ConverterParameter=1}"/>
                        <RadioButton GroupName="Speed" Content="2" Command="{Binding FastSpeedCommand}" Margin="3,0"
                                     IsChecked="{Binding SelectedSpeed, Converter={StaticResource SelectedButtonConverter}, ConverterParameter=2}"/>
                        <RadioButton GroupName="Speed" Content="4" Command="{Binding SuperFastSpeedCommand}" Margin="3,0"
                                     IsChecked="{Binding SelectedSpeed, Converter={StaticResource SelectedButtonConverter}, ConverterParameter=4}"/>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem Grid.Column="1" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="Speed" Command="{Binding EditorModeCommand}" Margin="3,0"
                                     IsChecked="{Binding SelectedSpeed, Converter={StaticResource SelectedButtonConverter}, ConverterParameter=0}">
                            <Image Source="/Assets/Images/Icons/tool.png" Stretch="Fill"/>
                        </RadioButton>
                        <Button Command="{Binding PauseGameCommand}" Margin="3,0">
                            <Image Source="/Assets/Images/Icons/pause.png" Stretch="Fill"/>
                        </Button>
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem Grid.Column="2" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Icons/coin.png" Width="35"/>
                        <TextBlock Margin="5,0,15,0" VerticalAlignment="Center" Text="{Binding Balance}"/>
                        <Image Source="/Assets/Images/Icons/hourglass.png" Width="35"/>
                        <TextBlock Margin="5,0,5,0" VerticalAlignment="Center" Text="{Binding GameDate, StringFormat={}{0:MMM dd yyyy}}" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="300"/>
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="8*" />
                </Grid.ColumnDefinitions>

                <!-- Left panel -->
                <usercontrols:LeftPanel Grid.Column="0"/>

                <!-- Right panel -->
                <usercontrols:Map x:Name="MainMapRenderer"
                              ViewModel="{Binding}"
                              Grid.Column="2"
                              BorderBrush="Black" BorderThickness="2"/>
                <usercontrols:MinimapControl
                              Grid.Column="2"
                              Margin="10"
                              BorderBrush="Black" BorderThickness="2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              TargetRenderer="{Binding GameMapRenderer, ElementName=MainMapRenderer}"/>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
