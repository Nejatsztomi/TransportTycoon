<Window x:Class="TransportTycoon.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TransportTycoon.WPF" xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
        mc:Ignorable="d"
        Title="Transport Tycoon - Game"
        Height="450"
        Width="800"
        MinHeight="450"
        MinWidth="800"
        >
    
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">

            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="1" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button Content="EDIT" Command="{Binding EditorModeCommand}" Margin="2,0" Padding="10,2" />
                    <Button Content="1x" Command="{Binding NormalSpeedCommand}" Margin="2,0" Padding="10,2" />
                    <Button Content="2x" Command="{Binding FastSpeedCommand}" Margin="2,0" Padding="10,2" />
                    <Button Content="4x" Command="{Binding SuperFastSpeedCommand}" Margin="2,0" Padding="10,2" />
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,10,0" Text="Balance: " />
                    <TextBlock Margin="0,0,10,0" Text="{Binding Balance}" />
                    <TextBlock Margin="0,0,10,0" Text="Time: " />
                    <TextBlock Margin="0,0,10,0" Text="{Binding GameTime}" />
                </StackPanel>
            </StatusBarItem>

        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />

                <ColumnDefinition Width="15" />

                <ColumnDefinition Width="8*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#ECECEC" CornerRadius="5">
                <TextBlock Text="20% Panel" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
            </Border>

            <Border Grid.Column="2" Background="#2C2C2C" CornerRadius="5" ClipToBounds="True">

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">

                    <ItemsControl ItemsSource="{Binding Tiles}">

                        <ItemsControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                        </ItemsControl.LayoutTransform>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid
                                    Columns="{Binding MapColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    Rows="{Binding MapRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="50" Height="50" BorderBrush="#404040" BorderThickness="1">
                                    <Border.Background>
                                        <!-- RenderOptions give more perfomance, but can make visual worse when zooming out too much -->
                                        <ImageBrush ImageSource="{Binding ImagePath}"
                                                    Stretch="UniformToFill"
                                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                    />
                                    </Border.Background>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>

            </Border>

        </Grid>

    </DockPanel>
</Window>
