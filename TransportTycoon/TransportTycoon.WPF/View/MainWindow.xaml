<Window x:Class="TransportTycoon.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TransportTycoon.WPF" xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
        mc:Ignorable="d"
        Title="Transport Tycoon - Game"
        Height="450"
        Width="800"
        MinHeight="450"
        MinWidth="800"
        >

    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">

            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="1" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button Content="EDIT" Command="{Binding EditorModeCommand}" Margin="2,0" Padding="10,2" />
                    <Button Content="1x" Command="{Binding NormalSpeedCommand}" Margin="2,0" Padding="10,2" />
                    <Button Content="2x" Command="{Binding FastSpeedCommand}" Margin="2,0" Padding="10,2" />
                    <Button Content="4x" Command="{Binding SuperFastSpeedCommand}" Margin="2,0" Padding="10,2" />
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,10,0" Text="Balance: " />
                    <TextBlock Margin="0,0,10,0" Text="{Binding Balance}" />
                    <TextBlock Margin="0,0,10,0" Text="Time: " />
                    <TextBlock Margin="0,0,10,0" Text="{Binding GameTime}" />
                </StackPanel>
            </StatusBarItem>

        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>

                <ColumnDefinition Width="15" />

                <ColumnDefinition Width="8*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0" Background="#ECECEC" CornerRadius="5">
                <!--<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Map Info" FontWeight="Bold" FontSize="18" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding SelectedTile}" FontSize="16" Foreground="#555" TextAlignment="Center" />
                </StackPanel>-->
                <TabControl Background="Transparent" BorderThickness="0">

                    <!-- TabItem-ek stílusa (kiegészítve a fejléc szövegének megjelenítésével) -->
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Width" Value="60"/>
                            <Setter Property="Height" Value="60"/>

                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#888" BorderThickness="1">
                                            <ContentPresenter x:Name="contentPresenter"
                                                                  ContentSource="Header"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="Black"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- Egyedi Template a vonal hozzáadásához -->
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="90"/>
                                    <!-- fejléc sora -->
                                    <RowDefinition Height="2"/>
                                    <!-- vonal sora -->
                                    <RowDefinition Height="*"/>
                                    <!-- tartalom sora -->
                                </Grid.RowDefinitions>

                                <!-- Fejléc panel (alapértelmezett TabPanel, görgethető) -->
                                <TabPanel Grid.Row="0"
                                              Name="HeaderPanel"
                                              Panel.ZIndex="1"
                                              KeyboardNavigation.TabIndex="1"
                                              IsItemsHost="True"
                                              HorizontalAlignment="Center" Margin="10"/>

                                <!-- Elválasztó vonal -->
                                <Border Grid.Row="1" Background="Gray" Margin="10,0"/>

                                <!-- Tartalom -->
                                <Border Grid.Row="2"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <!-- TabItem-ek-->
                    <TabItem>
                        <TabItem.Background>
                            <ImageBrush ImageSource="/Assets/Images/Terrain/hill.png" Stretch="UniformToFill"/>
                        </TabItem.Background>
                        <WrapPanel Margin="15" HorizontalAlignment="Center">
                            <Button Width="50" Height="50" Margin="6"/>
                            <Button Width="50" Height="50" Margin="6"/>
                            <Button Width="50" Height="50" Margin="6"/>
                            <Button Width="50" Height="50" Margin="6"/>
                            <Button Width="50" Height="50" Margin="6"/>
                        </WrapPanel>
                    </TabItem>

                    <TabItem>
                        <TabItem.Background>
                            <ImageBrush ImageSource="/Assets/Images/Road/road.png" Stretch="UniformToFill"/>
                        </TabItem.Background>
                        <WrapPanel Margin="15" HorizontalAlignment="Center">
                            <Button Width="50" Height="50" Margin="8"/>
                            <Button Width="50" Height="50" Margin="8"/>
                            <Button Width="50" Height="50" Margin="6"/>
                            <Button Width="50" Height="50" Margin="6"/>
                        </WrapPanel>
                    </TabItem>

                    <TabItem>
                        <TabItem.Background>
                            <ImageBrush ImageSource="/Assets/Images/Vehicle/largeBus.png" Stretch="UniformToFill"/>
                        </TabItem.Background>
                        <WrapPanel Margin="15" HorizontalAlignment="Center">
                            <Button Width="50" Height="50" Margin="8"/>
                            <Button Width="50" Height="50" Margin="6"/>
                        </WrapPanel>
                    </TabItem>

                    <TabItem>
                        <WrapPanel Margin="15" HorizontalAlignment="Center">
                            <Button Width="50" Height="50" Margin="8"/>
                        </WrapPanel>
                    </TabItem>

                </TabControl>

            </Border>

            <!-- Right panel -->
            <Border
                Grid.Column="2"
                Background="#2C2C2C"
                CornerRadius="5"
                ClipToBounds="True"
                >

                <ScrollViewer
                    x:Name="MapScrollViewer"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    
                    PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel"
                    PreviewMouseRightButtonDown="MapScrollViewer_PreviewMouseRightButtonDown"
                    PreviewMouseMove="MapScrollViewer_PreviewMouseMove"
                    PreviewMouseRightButtonUp="MapScrollViewer_PreviewMouseRightButtonUp"
                    >

                    <ItemsControl ItemsSource="{Binding Tiles}">

                        <ItemsControl.LayoutTransform>
                            <ScaleTransform
                                ScaleX="{Binding ZoomLevel}"
                                ScaleY="{Binding ZoomLevel}"
                                />
                        </ItemsControl.LayoutTransform>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid
                                    Columns="{Binding DataContext.MapColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    Rows="{Binding DataContext.MapRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Width="50"
                                    Height="50"
                                    Background="Transparent"
                                    >

                                    <Grid.InputBindings>
                                        <MouseBinding 
                                                      MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.TileClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                      CommandParameter="{Binding}"
                                                      />
                                    </Grid.InputBindings>

                                    <Border
                                            BorderBrush="#404040"
                                            BorderThickness="1"
                                            >
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ImagePath}" 
                                                        Stretch="UniformToFill" 
                                                        RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                        </Border.Background>
                                    </Border>

                                    <Border x:Name="HoverOverlay" 
                                            Visibility="Hidden" 
                                            BorderBrush="Yellow" 
                                            BorderThickness="2" 
                                            Background="#33FFFFFF" 
                                            IsHitTestVisible="False"
                                            />
                                </Grid>

                                <DataTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="HoverOverlay" Property="Visibility" Value="Visible" />

                                        <Setter Property="Panel.ZIndex" Value="1" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>

            </Border>

        </Grid>

    </DockPanel>
</Window>
