<UserControl x:Class="TransportTycoon.WPF.View.CreateGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TransportTycoon.WPF.View"
             xmlns:viewmodel="clr-namespace:TransportTycoon.WPF.ViewModel" d:DataContext="{d:DesignInstance Type=viewmodel:CreateGameViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Wheat"
             >
    
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="Create new game" FontSize="30" HorizontalAlignment="Center"/>

        <!-- Game specific setttings -->
        <StackPanel Margin="0 10 0 5" Orientation="Horizontal">
            <TextBlock Text="Save name: "/>
            <TextBox Text="{Binding SaveName}" Width="200" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Game width: "/>
            <TextBox Text="{Binding GameWidth}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Game height: "/>
            <TextBox Text="{Binding GameHeight}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Seed: "/>
            <TextBox Text="{Binding GameSeed}" Width="100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Starter balance: "/>
            <TextBox Text="{Binding GameStarterBalance}" Width="100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
        
        <TextBlock Text="Select difficulty" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <ComboBox SelectedIndex="{Binding SelectedDifficulty, FallbackValue=1}">
            <ComboBoxItem Content="Easy Mode"></ComboBoxItem>
            <ComboBoxItem Content="Medium Mode"></ComboBoxItem>
            <ComboBoxItem Content="Hard Mode"></ComboBoxItem>
        </ComboBox>

        <!-- Map generation settings -->
        <TextBlock Text="Select biome" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <ComboBox SelectedIndex="{Binding SettingsBiome, FallbackValue=0}">
            <ComboBoxItem Content="Default"></ComboBoxItem>
        </ComboBox>

        <TextBlock Text="Select water biome" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <ComboBox SelectedIndex="{Binding SettingsWaterBiome, FallbackValue=0}">
            <ComboBoxItem Content="Normal"></ComboBoxItem>
            <ComboBoxItem Content="Dry"></ComboBoxItem>
            <ComboBoxItem Content="Wet"></ComboBoxItem>
        </ComboBox>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Forest percentage: "/>
            <Slider Orientation="Horizontal" Width="200" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Value="{Binding SettingsForestPercentage}"
                    Minimum="0"
                    Maximum="100"
                    />
        </StackPanel>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="River count: "/>
            <TextBox Text="{Binding SettingsRiverCount}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
        
        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Minimum number of cities: "/>
            <TextBox Text="{Binding SettingsMinCities}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Maximum number of cities: "/>
            <TextBox Text="{Binding SettingsMaxCities}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Minimum number of structures: "/>
            <TextBox Text="{Binding SettingsMinStructures}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Margin="0 0 0 5" Orientation="Horizontal">
            <TextBlock Text="Maximum number of structures: "/>
            <TextBox Text="{Binding SettingsMaxStructures}" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Content="Create new game" Command="{Binding CreateNewGameCommand}"/>
        <Button Content="Back to menu" Command="{Binding BackToMainMenuCommand}"/>
    </StackPanel>
</UserControl>
